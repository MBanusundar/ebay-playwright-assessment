{
  "name": "ebay-related-products-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework for eBay Related Products feature testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:safari": "playwright test --project=webkit",
    "test:report": "playwright show-report",
    "test:ui": "playwright test --ui"
  },
  "keywords": ["playwright", "typescript", "automation", "ebay", "testing"],
  "author": "QA Team",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
